+def _merge_style_instruction(style_instruction: str = "") -> str:
+    """Keep a stable voice baseline while allowing small per-turn emotion hints."""
+    extra = " ".join(str(style_instruction or "").split())
+    if not extra:
+        return _DEFAULT_STYLE_INSTRUCTION
+    return (
+        f"{_DEFAULT_STYLE_INSTRUCTION}\n"
+        f"本轮情绪补充：{extra}\n"
+        "约束：本轮情绪补充只能调整语气强弱，不能改变默认少女感声音基底。"
+    )
